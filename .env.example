APP_NAME=ai-agent-mvp
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DB_PATH=./app_data/agent.db

# LLM
# Local developer-specific real-project overrides should go in .env.local
# (git-ignored). In real mode this project supports Gemini only via Vertex AI + ADC.
LLM_MODE=mock
GEMINI_MODEL=gemini-2.5-flash

# Vertex AI / google-genai (only required when LLM_MODE=vertex)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=True

# Logging
LOG_LEVEL=INFO

# Audit heuristics
LARGE_TX_THRESHOLD=100000
DEFAULT_SKILL_ID=asset_audit_basic
